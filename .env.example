# iCloud Mail MCP - Environment Variables
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# ICLOUD_EMAIL: Your Apple ID email address
ICLOUD_EMAIL=your_apple_id@icloud.com
#
# ICLOUD_APP_PASSWORD: An App-Specific Password (NOT your real iCloud password)
# Generate one at: https://appleid.apple.com -> Sign In -> App-Specific Passwords
# Format: xxxx-xxxx-xxxx-xxxx
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# ICLOUD_MCP_PYTHON: Path to the Python interpreter for the MCP server
# Defaults to "python" if not set
# Example for conda env: /Users/you/miniforge3/envs/datus/bin/python
ICLOUD_MCP_PYTHON=/usr/bin/python3
